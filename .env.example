#--------------------------------------------------------------------
# FESTAS LULINAS — Configuração de Ambiente
#
# Copie este arquivo para .env e preencha com os dados do seu ambiente.
# NUNCA suba o .env real para o git.
#
# Execute após configurar:
#   php spark migrate --all
#   php spark db:seed App\Database\Seeds\AdminSeeder
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
# Valores: development | production | testing
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://seudominio.com.br/'
# app.forceGlobalSecureRequests = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = nome_do_banco
database.default.username = usuario_do_banco
database.default.password = senha_do_banco
database.default.DBDriver = MySQLi
database.default.port     = 3306

# Banco de testes (não necessário em produção)
# database.tests.hostname = localhost
# database.tests.database = nome_do_banco_test
# database.tests.username = usuario_do_banco
# database.tests.password = senha_do_banco
# database.tests.DBDriver = MySQLi
# database.tests.port     = 3306

